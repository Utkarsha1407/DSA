class Solution {
  public:
    int findFloor(vector<int>& arr, int x) {
        // code here
        int start=0, end=arr.size()-1, ans=-1;
        
        while(start<=end)
        {
            int mid=start+(end-start)/2;
            if(arr[mid]<=x) {
            ans=mid;
            start=mid+1; //try to find big number
            }
            else {
                end=mid-1;
            }
        }
        return ans;
    }
};
